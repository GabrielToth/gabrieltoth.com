# Vercel Build Ignore File
# Files and directories to exclude from Vercel deployments

# Environment files with secrets
.env
.env.local
.env.*.local
.env.production
.env.development

# Secrets directory
.secrets/
.auth/

# Git
.git
.gitignore
.gitmessage

# Dependencies
node_modules/
.pnp
.pnp.js

# Testing
coverage/
.nyc_output/

# Build outputs
.next/
dist/
build/
out/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
tmp/
temp/
*.tmp

# Documentation
docs/
README.md
CHANGELOG.md

# CI/CD
.github/
.gitlab-ci.yml
.circleci/

# Docker
Dockerfile
docker-compose.yml
.dockerignore

# Other
.husky/
.lintstagedrc.json
.prettierignore
.eslintrc.json
.editorconfig
.nvmrc
.cursorrules
.hintrc
amplify.yml
audit.json
audit2.json
