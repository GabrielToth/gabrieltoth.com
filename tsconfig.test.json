{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "types": ["vitest/globals", "node", "@testing-library/jest-dom"]
  },
  "include": [
    "src/__tests__/**/*.ts",
    "src/__tests__/**/*.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ],
  "exclude": ["node_modules", "src/stories/**", "stories/**", "src/**/*.stories.ts", "src/**/*.stories.tsx"]
}
