# ============================================================================
# TEST ENVIRONMENT VARIABLES
# ============================================================================
# 
# ⚠️ IMPORTANT: DO NOT EDIT THIS FILE DIRECTLY!
# 
# 1. Copy this file to .env.test.local:
#    cp .env.test.example .env.test.local
# 
# 2. These settings override .env.local during Vitest runs to speed up execution
# 
# ============================================================================

# Make tests run fast by disabling memory-hardness for Argon2id
ARGON2_MEMORY_COST=16
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1
BCRYPT_COST_FACTOR=1

# Disable rate limit delays
RATE_LIMIT_FAILURE_THRESHOLD=100
RATE_LIMIT_WINDOW_MINUTES=1
RATE_LIMIT_LOCKOUT_MINUTES=1
RATE_LIMIT_CAPTCHA_ESCALATION_THRESHOLD=100

# Other Test Overrides
NEXT_PUBLIC_DEBUG=true
