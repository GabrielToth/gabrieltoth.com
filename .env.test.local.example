# ============================================================================
# TEST ENVIRONMENT OVERRIDES (Local Testing Only)
# ============================================================================
# 
# This file is for LOCAL TESTING ONLY and should NOT be committed to git.
# Copy this file to .env.test.local and modify values as needed for your tests.
# 
# .env.test.local is in .gitignore and will override .env.local during tests.
# 
# Usage:
# 1. Copy this file: cp .env.test.local.example .env.test.local
# 2. Modify values as needed for your specific tests
# 3. Run tests: npm run test
# 4. Tests will use .env.test.local values (if present) or fall back to .env.local
# 
# ============================================================================

# ============================================================================
# DEBUG FLAGS (Override for Testing)
# ============================================================================

# Enable debug output during tests
# GitHub: ❌ DO NOT COMMIT | Sensitive: No | Vercel: Not used
# DEBUG=true

# Enable client-side debug during tests
# GitHub: ❌ DO NOT COMMIT | Sensitive: No | Vercel: Not used
# NEXT_PUBLIC_DEBUG=true

# ============================================================================
# DATABASE (Override for Testing)
# ============================================================================

# Use test database instead of development database
# GitHub: ❌ DO NOT COMMIT | Sensitive: Yes | Vercel: Not used
# DATABASE_URL=postgres://test:test@localhost:5432/test_db

# ============================================================================
# RATE LIMITING (Override for Testing)
# ============================================================================

# Reduce rate limit thresholds for faster testing
# GitHub: ❌ DO NOT COMMIT | Sensitive: No | Vercel: Not used
# RATE_LIMIT_FAILURE_THRESHOLD=2

# Reduce window for faster testing
# GitHub: ❌ DO NOT COMMIT | Sensitive: No | Vercel: Not used
# RATE_LIMIT_WINDOW_MINUTES=1

# Reduce lockout duration for faster testing
# GitHub: ❌ DO NOT COMMIT | Sensitive: No | Vercel: Not used
# RATE_LIMIT_LOCKOUT_MINUTES=1

# ============================================================================
# CACHE (Override for Testing)
# ============================================================================

# Disable cache during tests for consistent results
# GitHub: ❌ DO NOT COMMIT | Sensitive: No | Vercel: Not used
# CACHE_ENABLED=false

# ============================================================================
# NOTIFICATIONS (Override for Testing)
# ============================================================================

# Disable Discord notifications during tests
# GitHub: ❌ DO NOT COMMIT | Sensitive: No | Vercel: Not used
# SEND_DISCORD_IN_TESTS=false

# ============================================================================
# EXTERNAL SERVICES (Override for Testing)
# ============================================================================

# Use mock/test endpoints instead of production
# GitHub: ❌ DO NOT COMMIT | Sensitive: No | Vercel: Not used
# GEOIP_SERVICE_URL=http://localhost:3000/api/test/geoip

# ============================================================================
# NOTES
# ============================================================================
# 
# This file allows you to override specific variables for testing without
# affecting your main .env.local configuration.
# 
# Common use cases:
# - Use test database instead of development database
# - Disable external service calls (Discord, GeoIP, etc.)
# - Reduce rate limiting thresholds for faster testing
# - Disable caching for consistent test results
# - Enable debug flags for troubleshooting
# 
# Remember: This file is in .gitignore and should NEVER be committed.
# 
# ============================================================================
