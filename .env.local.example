# ============================================================================
# LOCAL DEVELOPMENT ENVIRONMENT VARIABLES
# ============================================================================
# 
# ⚠️ IMPORTANT: DO NOT EDIT THIS FILE DIRECTLY!
# 
# 1. Copy this file to .env.local:
#    cp .env.local.example .env.local
# 
# 2. Fill in your actual values in .env.local
# 
# 3. Never commit .env.local to git (it's in .gitignore)
# 
# ============================================================================
# 
# VERCEL DEPLOYMENT NOTES:
# 
# When deploying to Vercel, add these variables to Project Settings > Environment Variables:
# 
# SENSITIVE VARIABLES (Mark as "Sensitive" in Vercel):
# - GOOGLE_CLIENT_SECRET
# - SUPABASE_SERVICE_ROLE_KEY
# - STRIPE_SECRET_KEY
# - RESEND_API_KEY
# - YOUTUBE_CLIENT_SECRET
# - TOKEN_ENCRYPTION_KEY
# - JWT_SECRET
# - GEOIP_API_KEY
# - DISCORD_WEBHOOK_URL
# 
# PUBLIC VARIABLES (Do NOT mark as sensitive):
# - All NEXT_PUBLIC_* variables (these are exposed to browser by design)
# - DEPLOYMENT_TYPE
# - DEBUG
# - BCRYPT_COST_FACTOR
# - SESSION_TIMEOUT
# - VERIFICATION_TOKEN_EXPIRY
# - CACHE_ENABLED
# - CACHE_TTL
# - CACHE_MAX_MEMORY
# - USE_REDIS
# - SMTP_HOST
# - SMTP_PORT
# - SMTP_USER
# - SMTP_FROM_EMAIL
# - SMTP_FROM_NAME
# - GEOIP_SERVICE_URL
# - YOUTUBE_REDIRECT_URI
# 
# ============================================================================

# ============================================================================
# GENERAL SETTINGS
# ============================================================================

# Node environment (always "development" for local)
NODE_ENV=development

# Deployment type (local or cloud)
# Used by: src/config/environment.ts
# Vercel: ❌ PUBLIC | 🟢 Development
DEPLOYMENT_TYPE=local

# Server-side debug logs (true = verbose logging)
# Used by: src/lib/logger/pino-logger.ts
# Vercel: ❌ PUBLIC | 🟢 Development
DEBUG=true

# Client-side debug UI (true = enables debug panels in browser)
# Used by: src/app/[locale]/iq-test/step/[step]/page.tsx
# Append ?debug=1 to URLs to see debug panel
# Vercel: ❌ PUBLIC | 🟢 Development
NEXT_PUBLIC_DEBUG=false

# Application URLs
# Used by: src/config/environment.ts
# Vercel: ❌ PUBLIC | 🟢 Development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Vercel: ❌ PUBLIC | 🟢 Development
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ============================================================================
# DATABASE (Docker/Local Postgres)
# ============================================================================
# 
# If using Docker:
# 1. Run: cd docker && docker compose up -d postgres
# 2. Use the values below (they match docker-compose.yml)
# 
# If using local Postgres:
# 1. Install Postgres: https://www.postgresql.org/download/
# 2. Create database: createdb platform
# 3. Create user: createuser -P platform (password: devpassword)
# 4. Update DATABASE_URL with your credentials
# 
# ============================================================================

# Vercel: ✅ SENSITIVE | 🟢 Development (local only)
DATABASE_URL=postgres://platform:devpassword@localhost:5432/platform
# Vercel: ❌ PUBLIC | 🟢 Development (local only)
POSTGRES_USER=platform
# Vercel: ✅ SENSITIVE | 🟢 Development (local only)
POSTGRES_PASSWORD=devpassword
# Vercel: ❌ PUBLIC | 🟢 Development (local only)
POSTGRES_DB=platform

# ============================================================================
# REDIS (Optional - for caching, not implemented yet)
# ============================================================================
# 
# If using Docker:
# 1. Run: cd docker && docker compose up -d redis
# 2. Use: redis://localhost:6379
# 
# If using local Redis:
# 1. Install Redis: https://redis.io/docs/getting-started/
# 2. Start Redis: redis-server
# 3. Use: redis://localhost:6379
# 
# ============================================================================

# Vercel: ✅ SENSITIVE | 🟢 Development (local only)
REDIS_URL=redis://localhost:6379

# ============================================================================
# JWT SECRET (Required for OAuth Registration)
# ============================================================================
# 
# Secret key for signing temporary JWT tokens during OAuth registration.
# These tokens are used to securely pass OAuth user data between the
# callback and completion endpoints.
# 
# How to generate a secure JWT secret:
# 
# 1. Use a cryptographically secure random string generator:
#    - Node.js: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#    - OpenSSL: openssl rand -hex 64
#    - Online: https://generate-secret.vercel.app/64
# 
# 2. Copy the generated string
# 3. Fill in the value below
# 
# Note: Keep this secret secure! Never commit it to git or share it publicly.
#       Use a different secret for production.
# 
# ============================================================================

# Vercel: ✅ SENSITIVE | 🔴 Production, 🟡 Preview
JWT_SECRET=your-jwt-secret-key-here

# ============================================================================
# GOOGLE OAUTH (Required for Google Login)
# ============================================================================
# 
# How to get Google OAuth credentials:
# 
# 1. Go to: https://console.cloud.google.com/
# 2. Create a new project or select existing
# 3. Enable "Google+ API":
#    - Go to "APIs & Services" > "Library"
#    - Search for "Google+ API"
#    - Click "Enable"
# 4. Create OAuth 2.0 credentials:
#    - Go to "APIs & Services" > "Credentials"
#    - Click "Create Credentials" > "OAuth client ID"
#    - Application type: "Web application"
#    - Name: "gabrieltoth.com - Development"
#    - Authorized JavaScript origins:
#      * http://localhost:3000
#    - Authorized redirect URIs:
#      * http://localhost:3000/api/auth/google/callback
#    - Click "Create"
# 5. Copy "Client ID" and "Client secret"
# 6. Fill in the values below
# 
# Note: GOOGLE_CLIENT_ID is server-only (never exposed to browser)
#       NEXT_PUBLIC_GOOGLE_CLIENT_ID is client-side (exposed to browser)
#       Both should have the same value for development
# 
# ============================================================================

# Vercel: ❌ PUBLIC | 🟢 Development
GOOGLE_CLIENT_ID=your-google-client-id-here
# Vercel: ✅ SENSITIVE | 🔴 Production, 🟡 Preview
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
# Vercel: ❌ PUBLIC | 🟢 Development
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id-here
# Vercel: ❌ PUBLIC | 🟢 Development
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ============================================================================
# AUTHENTICATION & REGISTRATION (Required for enhanced registration)
# ============================================================================
# 
# Configuration for the enhanced authentication registration flow
# 
# ============================================================================

# API URL for registration endpoints
# Used by: src/components/registration/RegistrationFlow.tsx
# Local: http://localhost:3000/api
# Production: https://api.production.com
# Vercel: ❌ PUBLIC | 🟢 Development
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Bcrypt cost factor for password hashing (10-12 recommended)
# Higher = more secure but slower
# Used by: src/lib/auth/password-hashing.ts
# 
# Recommended values:
# - Development: 10 (faster, less secure)
# - Production: 12 (slower, more secure)
# 
# Cost factor determines how many iterations bcrypt uses:
# - 10: ~10ms per hash
# - 11: ~20ms per hash
# - 12: ~40ms per hash
# 
# Vercel: ❌ PUBLIC | 🟢 Development
BCRYPT_COST_FACTOR=10

# Session timeout in milliseconds (30 minutes = 1800000)
# Used by: src/lib/auth/session.ts
# 
# This controls how long a registration session persists before expiring.
# After this time, users must start the registration process over.
# 
# Common values:
# - 30 minutes: 1800000 (recommended for registration)
# - 1 hour: 3600000
# - 2 hours: 7200000
# 
# Vercel: ❌ PUBLIC | 🟢 Development
SESSION_TIMEOUT=1800000

# Email verification token expiry in milliseconds (24 hours = 86400000)
# Used by: src/lib/auth/temp-token.ts
# 
# This controls how long email verification links remain valid.
# After this time, users must request a new verification email.
# 
# Common values:
# - 24 hours: 86400000 (recommended)
# - 48 hours: 172800000
# - 7 days: 604800000
# 
# Vercel: ❌ PUBLIC | 🟢 Development
VERIFICATION_TOKEN_EXPIRY=86400000

# Cache configuration
# Used by: src/config/environment.ts
# Vercel: ❌ PUBLIC | 🟢 Development
CACHE_ENABLED=true
# Vercel: ❌ PUBLIC | 🟢 Development
CACHE_TTL=3600
# Vercel: ❌ PUBLIC | 🟢 Development
CACHE_MAX_MEMORY=256mb
# Vercel: ❌ PUBLIC | 🟢 Development
USE_REDIS=true

# SMTP Configuration for sending verification emails
# Used by: src/lib/auth/email-service.ts
# 
# How to set up Gmail SMTP:
# 
# 1. Enable 2-Factor Authentication on your Google account:
#    - Go to: https://myaccount.google.com/security
#    - Enable "2-Step Verification"
# 
# 2. Generate an App Password:
#    - Go to: https://myaccount.google.com/apppasswords
#    - Select "Mail" and "Windows Computer" (or your device)
#    - Google will generate a 16-character password
#    - Copy this password to SMTP_PASSWORD below
# 
# 3. Fill in the values:
#    - SMTP_HOST: smtp.gmail.com (for Gmail)
#    - SMTP_PORT: 587 (TLS) or 465 (SSL)
#    - SMTP_USER: your-email@gmail.com
#    - SMTP_PASSWORD: your-16-character-app-password
#    - SMTP_FROM_EMAIL: noreply@gabrieltoth.com (or your domain)
#    - SMTP_FROM_NAME: Gabriel Toth (or your name)
# 
# For other email providers:
# - SendGrid: smtp.sendgrid.net:587, user: apikey, password: SG.xxxxx
# - Mailgun: smtp.mailgun.org:587, user: postmaster@xxx, password: xxxxx
# - AWS SES: email-smtp.region.amazonaws.com:587, user: AKIA..., password: xxxxx
# 
# Vercel: ❌ PUBLIC | 🟢 Development
SMTP_HOST=smtp.gmail.com
# Vercel: ❌ PUBLIC | 🟢 Development
SMTP_PORT=587
# Vercel: ❌ PUBLIC | 🟢 Development
SMTP_USER=your-email@gmail.com
# Vercel: ✅ SENSITIVE | 🔴 Production, 🟡 Preview
SMTP_PASSWORD=your-app-password
# Vercel: ❌ PUBLIC | 🟢 Development
SMTP_FROM_EMAIL=noreply@gabrieltoth.com
# Vercel: ❌ PUBLIC | 🟢 Development
SMTP_FROM_NAME=Gabriel Toth

# ============================================================================
# SUPABASE (Required for database and auth)
# ============================================================================
# 
# How to get Supabase credentials:
# 
# 1. Go to: https://supabase.com/
# 2. Sign up or log in
# 3. Create a new project:
#    - Click "New Project"
#    - Name: "gabrieltoth-dev"
#    - Database Password: (choose a strong password)
#    - Region: (choose closest to you)
#    - Click "Create new project"
# 4. Wait for project to be ready (~2 minutes)
# 5. Go to "Settings" > "API"
# 6. Copy the following:
#    - Project URL → NEXT_PUBLIC_SUPABASE_URL
#    - anon/public key → NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
#    - service_role key → SUPABASE_SERVICE_ROLE_KEY (⚠️ Keep secret!)
# 7. Fill in the values below
# 
# Note: SUPABASE_SERVICE_ROLE_KEY bypasses Row Level Security (RLS)
#       Only use in tests or server-side code, never expose to client
# 
# ============================================================================

NEXT_PUBLIC_SUPABASE_URL=your-supabase-url-here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key-here
# Vercel: ✅ SENSITIVE
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ============================================================================
# STRIPE (Required for payments)
# ============================================================================
# 
# How to get Stripe credentials:
# 
# 1. Go to: https://dashboard.stripe.com/register
# 2. Sign up or log in
# 3. Activate your account (provide business details)
# 4. Go to "Developers" > "API keys"
# 5. Toggle "Test mode" ON (top right)
# 6. Copy "Secret key" (starts with sk_test_)
# 7. Fill in the value below
# 
# Note: Use test keys for development (sk_test_)
#       Use live keys for production (sk_live_)
# 
# ============================================================================

# Vercel: ✅ SENSITIVE
STRIPE_SECRET_KEY=your-stripe-secret-key-here

# ============================================================================
# RESEND (Required for sending emails)
# ============================================================================
# 
# How to get Resend API key:
# 
# 1. Go to: https://resend.com/
# 2. Sign up or log in
# 3. Go to "API Keys"
# 4. Create a new API key
# 5. Copy the API key
# 6. Fill in the value below
# 
# Note: Resend is used for sending verification emails and password reset emails
# 
# ============================================================================

# Vercel: ✅ SENSITIVE
RESEND_API_KEY=re_VWxKqtVX_P3RnmWcVcT9o9mEpEfsVzALJ

# ============================================================================
# DISCORD WEBHOOK (Optional - for notifications)
# ============================================================================
# 
# How to get Discord webhook URL:
# 
# 1. Open Discord
# 2. Go to your server
# 3. Right-click on a text channel > "Edit Channel"
# 4. Go to "Integrations" > "Webhooks"
# 5. Click "New Webhook"
# 6. Name: "gabrieltoth.com Notifications"
# 7. Copy "Webhook URL"
# 8. Fill in the value below
# 
# What it's used for:
# - User registration notifications
# - User login notifications
# - Test notifications (if SEND_DISCORD_IN_TESTS=true)
# 
# ============================================================================

# Vercel: ✅ SENSITIVE
SEND_DISCORD_IN_TESTS=true
# Vercel: ✅ SENSITIVE
DISCORD_WEBHOOK_URL=your-discord-webhook-url-here

# ============================================================================
# AMAZON ASSOCIATES (Optional - for affiliate links)
# ============================================================================
# 
# How to get Amazon Associates tag:
# 
# 1. Go to: https://affiliate-program.amazon.com/
# 2. Sign up or log in
# 3. Complete the application
# 4. Once approved, go to "Tools" > "Product Links"
# 5. Your tracking ID is shown at the top (format: yourname-20)
# 6. Fill in the value below
# 
# What it's used for:
# - Affiliate links on /amazon-affiliate page
# - Earn commission on Amazon purchases
# 
# ============================================================================

# Vercel: ❌ PUBLIC
NEXT_PUBLIC_AMAZON_ASSOCIATES_TAG=your-amazon-tag-here

# ============================================================================
# MONERO (Optional - for cryptocurrency payments)
# ============================================================================
# 
# How to get Monero credentials:
# 
# 1. Download Monero wallet: https://www.getmonero.org/downloads/
# 2. Create a new wallet or restore existing
# 3. Go to "Settings" > "Seed & keys"
# 4. Copy:
#    - Primary address → MONERO_ADDRESS
#    - Private view key → MONERO_VIEW_KEY
# 5. Fill in the values below
# 
# What it's used for:
# - Accept Monero payments
# - Verify payment transactions
# - Display payment QR codes
# 
# Note: View key allows read-only access to transactions
#       Never share your spend key!
# 
# ============================================================================

# Vercel: ✅ SENSITIVE
MONERO_ADDRESS=your-monero-address-here
# Vercel: ✅ SENSITIVE
MONERO_VIEW_KEY=your-monero-view-key-here

# ============================================================================
# YOUTUBE OAUTH (Required for YouTube Channel Linking)
# ============================================================================
# 
# How to get YouTube OAuth credentials:
# 
# 1. Go to: https://console.cloud.google.com/
# 2. Create a new project or select existing
# 3. Enable "YouTube Data API v3":
#    - Go to "APIs & Services" > "Library"
#    - Search for "YouTube Data API v3"
#    - Click "Enable"
# 4. Create OAuth 2.0 credentials:
#    - Go to "APIs & Services" > "Credentials"
#    - Click "Create Credentials" > "OAuth client ID"
#    - Application type: "Web application"
#    - Name: "gabrieltoth.com - YouTube Linking"
#    - Authorized JavaScript origins:
#      * http://localhost:3000
#      * https://gabrieltoth.com
#    - Authorized redirect URIs:
#      * http://localhost:3000/api/youtube/link/callback
#      * https://gabrieltoth.com/api/youtube/link/callback
#    - Click "Create"
# 5. Copy "Client ID" and "Client secret"
# 6. Fill in the values below
# 
# Note: YOUTUBE_CLIENT_ID is server-only (never exposed to browser)
#       YOUTUBE_CLIENT_SECRET is sensitive - keep it secret!
# 
# ============================================================================

YOUTUBE_CLIENT_ID=your-youtube-client-id-here
# Vercel: ✅ SENSITIVE
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret-here
# Vercel: ❌ PUBLIC
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/youtube/link/callback

# ============================================================================
# EMAIL SERVICE (Required for YouTube Channel Linking Notifications)
# ============================================================================
# 
# Configuration for sending verification emails, notifications, and alerts
# 
# How to set up Gmail SMTP:
# 
# 1. Enable 2-Factor Authentication on your Google account:
#    - Go to: https://myaccount.google.com/security
#    - Enable "2-Step Verification"
# 
# 2. Generate an App Password:
#    - Go to: https://myaccount.google.com/apppasswords
#    - Select "Mail" and "Windows Computer" (or your device)
#    - Google will generate a 16-character password
#    - Copy this password to SMTP_PASSWORD below
# 
# 3. Fill in the values:
#    - SMTP_HOST: smtp.gmail.com (for Gmail)
#    - SMTP_PORT: 587 (TLS) or 465 (SSL)
#    - SMTP_USER: your-email@gmail.com
#    - SMTP_PASSWORD: your-16-character-app-password
#    - SMTP_FROM_EMAIL: noreply@gabrieltoth.com (or your domain)
#    - SMTP_FROM_NAME: Gabriel Toth (or your name)
# 
# For other email providers:
# - SendGrid: smtp.sendgrid.net:587, user: apikey, password: SG.xxxxx
# - Mailgun: smtp.mailgun.org:587, user: postmaster@xxx, password: xxxxx
# - AWS SES: email-smtp.region.amazonaws.com:587, user: AKIA..., password: xxxxx
# 
# ============================================================================

# Vercel: ❌ PUBLIC
SMTP_HOST=smtp.gmail.com
# Vercel: ❌ PUBLIC
SMTP_PORT=587
# Vercel: ❌ PUBLIC
SMTP_USER=your-email@gmail.com
# Vercel: ✅ SENSITIVE
SMTP_PASSWORD=your-app-password
# Vercel: ❌ PUBLIC
SMTP_FROM_EMAIL=noreply@gabrieltoth.com
# Vercel: ❌ PUBLIC
SMTP_FROM_NAME=Gabriel Toth

# ============================================================================
# GEOLOCATION SERVICE (Required for Suspicious Activity Detection)
# ============================================================================
# 
# Configuration for IP geolocation and device tracking
# 
# How to get MaxMind GeoIP2 credentials:
# 
# 1. Go to: https://www.maxmind.com/en/geoip2-services
# 2. Sign up for a free account
# 3. Go to "Account" > "My License Key"
# 4. Generate a new license key
# 5. Copy the Account ID and License Key
# 6. Fill in the values below
# 
# Alternative services:
# - IP2Location: https://www.ip2location.com/
# - GeoIP2: https://www.maxmind.com/
# - ipstack: https://ipstack.com/
# 
# ============================================================================

# Vercel: ❌ PUBLIC
GEOIP_SERVICE_URL=https://geoip.maxmind.com/geoip/v2.1/city
# Vercel: ✅ SENSITIVE
GEOIP_API_KEY=your-maxmind-license-key-here

# ============================================================================
# TOKEN ENCRYPTION (Required for YouTube OAuth Token Storage)
# ============================================================================
# 
# Encryption key for storing OAuth tokens securely
# 
# How to generate a secure encryption key:
# 
# 1. Use a cryptographically secure random string generator:
#    - Node.js: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#    - OpenSSL: openssl rand -hex 32
#    - Online: https://generate-secret.vercel.app/64
# 
# 2. Copy the generated 64-character hex string
# 3. Fill in the value below
# 
# Note: Keep this secret! Never commit it to git or share it publicly.
#       Use a different key for production.
# 
# ============================================================================

# Vercel: ✅ SENSITIVE
TOKEN_ENCRYPTION_KEY=your-64-character-hex-encryption-key-here

