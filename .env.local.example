# ============================================================================
# LOCAL DEVELOPMENT ENVIRONMENT VARIABLES
# ============================================================================
# 
# ⚠️ IMPORTANT: DO NOT EDIT THIS FILE DIRECTLY!
# 
# 1. Copy this file to .env.local:
#    cp .env.local.example .env.local
# 
# 2. Fill in your actual values in .env.local
# 
# 3. Never commit .env.local to git (it's in .gitignore)
# 
# ============================================================================

# ============================================================================
# GENERAL SETTINGS
# ============================================================================

# Node environment (always "development" for local)
NODE_ENV=development

# Server-side debug logs (true = verbose logging)
# Used by: src/lib/logger/pino-logger.ts
DEBUG=true

# Client-side debug UI (true = enables debug panels in browser)
# Used by: src/app/[locale]/iq-test/step/[step]/page.tsx
# Append ?debug=1 to URLs to see debug panel
NEXT_PUBLIC_DEBUG=false

# ============================================================================
# DATABASE (Docker/Local Postgres)
# ============================================================================
# 
# If using Docker:
# 1. Run: cd docker && docker compose up -d postgres
# 2. Use the values below (they match docker-compose.yml)
# 
# If using local Postgres:
# 1. Install Postgres: https://www.postgresql.org/download/
# 2. Create database: createdb platform
# 3. Create user: createuser -P platform (password: devpassword)
# 4. Update DATABASE_URL with your credentials
# 
# ============================================================================

DATABASE_URL=postgres://platform:devpassword@localhost:5432/platform
POSTGRES_USER=platform
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=platform

# ============================================================================
# REDIS (Optional - for caching, not implemented yet)
# ============================================================================
# 
# If using Docker:
# 1. Run: cd docker && docker compose up -d redis
# 2. Use: redis://localhost:6379
# 
# If using local Redis:
# 1. Install Redis: https://redis.io/docs/getting-started/
# 2. Start Redis: redis-server
# 3. Use: redis://localhost:6379
# 
# ============================================================================

REDIS_URL=redis://localhost:6379

# ============================================================================
# JWT SECRET (Required for OAuth Registration)
# ============================================================================
# 
# Secret key for signing temporary JWT tokens during OAuth registration.
# These tokens are used to securely pass OAuth user data between the
# callback and completion endpoints.
# 
# How to generate a secure JWT secret:
# 
# 1. Use a cryptographically secure random string generator:
#    - Node.js: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#    - OpenSSL: openssl rand -hex 64
#    - Online: https://generate-secret.vercel.app/64
# 
# 2. Copy the generated string
# 3. Fill in the value below
# 
# Note: Keep this secret secure! Never commit it to git or share it publicly.
#       Use a different secret for production.
# 
# ============================================================================

JWT_SECRET=your-jwt-secret-key-here

# ============================================================================
# GOOGLE OAUTH (Required for Google Login)
# ============================================================================
# 
# How to get Google OAuth credentials:
# 
# 1. Go to: https://console.cloud.google.com/
# 2. Create a new project or select existing
# 3. Enable "Google+ API":
#    - Go to "APIs & Services" > "Library"
#    - Search for "Google+ API"
#    - Click "Enable"
# 4. Create OAuth 2.0 credentials:
#    - Go to "APIs & Services" > "Credentials"
#    - Click "Create Credentials" > "OAuth client ID"
#    - Application type: "Web application"
#    - Name: "gabrieltoth.com - Development"
#    - Authorized JavaScript origins:
#      * http://localhost:3000
#    - Authorized redirect URIs:
#      * http://localhost:3000/api/auth/google/callback
#    - Click "Create"
# 5. Copy "Client ID" and "Client secret"
# 6. Fill in the values below
# 
# Note: GOOGLE_CLIENT_ID is server-only (never exposed to browser)
#       NEXT_PUBLIC_GOOGLE_CLIENT_ID is client-side (exposed to browser)
#       Both should have the same value for development
# 
# ============================================================================

GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id-here
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ============================================================================
# SUPABASE (Required for database and auth)
# ============================================================================
# 
# How to get Supabase credentials:
# 
# 1. Go to: https://supabase.com/
# 2. Sign up or log in
# 3. Create a new project:
#    - Click "New Project"
#    - Name: "gabrieltoth-dev"
#    - Database Password: (choose a strong password)
#    - Region: (choose closest to you)
#    - Click "Create new project"
# 4. Wait for project to be ready (~2 minutes)
# 5. Go to "Settings" > "API"
# 6. Copy the following:
#    - Project URL → NEXT_PUBLIC_SUPABASE_URL
#    - anon/public key → NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
#    - service_role key → SUPABASE_SERVICE_ROLE_KEY (⚠️ Keep secret!)
# 7. Fill in the values below
# 
# Note: SUPABASE_SERVICE_ROLE_KEY bypasses Row Level Security (RLS)
#       Only use in tests or server-side code, never expose to client
# 
# ============================================================================

NEXT_PUBLIC_SUPABASE_URL=your-supabase-url-here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ============================================================================
# STRIPE (Required for payments)
# ============================================================================
# 
# How to get Stripe credentials:
# 
# 1. Go to: https://dashboard.stripe.com/register
# 2. Sign up or log in
# 3. Activate your account (provide business details)
# 4. Go to "Developers" > "API keys"
# 5. Toggle "Test mode" ON (top right)
# 6. Copy "Secret key" (starts with sk_test_)
# 7. Fill in the value below
# 
# Note: Use test keys for development (sk_test_)
#       Use live keys for production (sk_live_)
# 
# ============================================================================

STRIPE_SECRET_KEY=your-stripe-secret-key-here

# ============================================================================
# DISCORD WEBHOOK (Optional - for notifications)
# ============================================================================
# 
# How to get Discord webhook URL:
# 
# 1. Open Discord
# 2. Go to your server
# 3. Right-click on a text channel > "Edit Channel"
# 4. Go to "Integrations" > "Webhooks"
# 5. Click "New Webhook"
# 6. Name: "gabrieltoth.com Notifications"
# 7. Copy "Webhook URL"
# 8. Fill in the value below
# 
# What it's used for:
# - User registration notifications
# - User login notifications
# - Test notifications (if SEND_DISCORD_IN_TESTS=true)
# 
# ============================================================================

SEND_DISCORD_IN_TESTS=true
DISCORD_WEBHOOK_URL=your-discord-webhook-url-here

# ============================================================================
# AMAZON ASSOCIATES (Optional - for affiliate links)
# ============================================================================
# 
# How to get Amazon Associates tag:
# 
# 1. Go to: https://affiliate-program.amazon.com/
# 2. Sign up or log in
# 3. Complete the application
# 4. Once approved, go to "Tools" > "Product Links"
# 5. Your tracking ID is shown at the top (format: yourname-20)
# 6. Fill in the value below
# 
# What it's used for:
# - Affiliate links on /amazon-affiliate page
# - Earn commission on Amazon purchases
# 
# ============================================================================

NEXT_PUBLIC_AMAZON_ASSOCIATES_TAG=your-amazon-tag-here

# ============================================================================
# MONERO (Optional - for cryptocurrency payments)
# ============================================================================
# 
# How to get Monero credentials:
# 
# 1. Download Monero wallet: https://www.getmonero.org/downloads/
# 2. Create a new wallet or restore existing
# 3. Go to "Settings" > "Seed & keys"
# 4. Copy:
#    - Primary address → MONERO_ADDRESS
#    - Private view key → MONERO_VIEW_KEY
# 5. Fill in the values below
# 
# What it's used for:
# - Accept Monero payments
# - Verify payment transactions
# - Display payment QR codes
# 
# Note: View key allows read-only access to transactions
#       Never share your spend key!
# 
# ============================================================================

MONERO_ADDRESS=your-monero-address-here
MONERO_VIEW_KEY=your-monero-view-key-here

# ============================================================================
# OPTIONAL / NOT IMPLEMENTED YET
# ============================================================================
# 
# The following variables are for features not yet implemented:
# - WhatsApp Business API (notifications)
# - PIX payments (Brazilian payment method)
# - GitHub token (for MCP integration)
# - Postman API (for MCP integration)
# 
# You can safely ignore these for now.
# 
# ============================================================================

# WhatsApp Business API (not implemented)
# WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
# WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
# WHATSAPP_VERIFY_TOKEN=your-whatsapp-verify-token

# PIX Payments (not implemented)
# PIX_KEY=your-pix-key
# PIX_MERCHANT_CITY=your-city
# PIX_MERCHANT_NAME=your-name

# MCP Integrations (optional)
# GITHUB_TOKEN=your-github-token
# POSTMAN_API_KEY=your-postman-api-key

# ============================================================================
# SUMMARY
# ============================================================================
# 
# Minimum required for basic development:
# ✅ NODE_ENV, DEBUG, NEXT_PUBLIC_DEBUG
# 
# Required for full functionality:
# ✅ Google OAuth (login)
# ✅ Supabase (database)
# ✅ Stripe (payments)
# 
# Optional but recommended:
# ⚠️ Discord Webhook (notifications)
# ⚠️ Amazon Associates (affiliate links)
# 
# Optional for specific features:
# ⚠️ Monero (crypto payments)
# ⚠️ Database/Redis (if using Docker)
# 
# ============================================================================
