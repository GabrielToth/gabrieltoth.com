# Production Environment Variables
# Domain: https://www.gabrieltoth.com
# Copy this file to .env.production and fill in the values

# General
NODE_ENV=production
BASE_URL=https://www.gabrieltoth.com
APP_URL=https://www.gabrieltoth.com
NEXT_PUBLIC_DEBUG=false

# Google OAuth (Production)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=https://www.gabrieltoth.com/api/auth/google/callback

# Supabase (Production)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Database (Production)
DATABASE_URL=your-database-url
REDIS_URL=your-redis-url

# Discord Webhook
DISCORD_WEBHOOK_URL=your-discord-webhook-url

# WhatsApp Business API
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-whatsapp-verify-token

# PIX Configuration
PIX_KEY=your-pix-key
PIX_MERCHANT_NAME=your-merchant-name
PIX_MERCHANT_CITY=your-city

# Monero Configuration
MONERO_ADDRESS=your-monero-address
MONERO_VIEW_KEY=your-monero-view-key

# Amazon Associates
NEXT_PUBLIC_AMAZON_ASSOCIATES_TAG=your-amazon-tag

# Meta/Facebook (Production)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# Instagram API
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret

# TikTok API
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret

# AWS Credentials
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_PROFILE=default

# Stripe API Keys
STRIPE_PUBLIC_KEY=your-stripe-public-key
STRIPE_SECRET_KEY=your-stripe-secret-key

# Postman API
POSTMAN_API_KEY=your-postman-api-key

# Encryption
ENCRYPTION_KEY=your-32-byte-encryption-key-here-change-this
