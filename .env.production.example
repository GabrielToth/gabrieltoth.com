# ============================================================================
# PRODUCTION ENVIRONMENT VARIABLES
# ============================================================================
# 
# ⚠️ IMPORTANT: DO NOT EDIT THIS FILE DIRECTLY!
# 
# 1. Copy this file to .env.production:
#    cp .env.production.example .env.production
# 
# 2. Fill in your actual PRODUCTION values in .env.production
# 
# 3. Never commit .env.production to git (it's in .gitignore)
# 
# 4. For Vercel deployment, set these in Project Settings > Environment Variables
# 
# ============================================================================
#
# VARIABLE TAG LEGEND (each variable below uses one of these lines):
#
#   GitHub: ❌ DO NOT COMMIT | Vercel: ✅ SENSITIVE - Production/Preview
#     → Real secret. Set in Vercel only; enable "Sensitive" in the dashboard.
#     → Copy to local .env.production for dev (never commit that file).
#
#   GitHub: ❌ DO NOT COMMIT | Vercel: ⚪ NOT SENSITIVE - Production/Preview
#     → Production value in Vercel; do not mark "Sensitive" (public or config).
#
#   GitHub: ✅ COMMIT | Vercel: ⚪ NOT SENSITIVE - Production/Preview
#     → Safe placeholder in this .example file; same value in Vercel if needed.
#
# Vercel scopes: Production, Preview (and Development only when noted).
# "Sensitive" is a Vercel dashboard option only — not a GitHub concept.
#
# ============================================================================

# ============================================================================
# GENERAL SETTINGS
# ============================================================================

# Node environment — set automatically by Vercel; do not add to Vercel dashboard
# GitHub: ❌ DO NOT COMMIT | Vercel: N/A (platform-managed)

# Single debug flag (server + client via next.config). Must be false in production.
# GitHub: ❌ DO NOT COMMIT | Vercel: ⚪ NOT SENSITIVE - Production/Preview
DEBUG=false

# Application URL (your production domain — API is always {APP_URL}/api)
# GitHub: ❌ DO NOT COMMIT | Vercel: ⚪ NOT SENSITIVE - Production/Preview
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ============================================================================
# GOOGLE OAUTH (Required for Google Login)
# ============================================================================
# 
# How to set up for production:
# 
# 1. Go to: https://console.cloud.google.com/
# 2. Select your project
# 3. Go to "APIs & Services" > "Credentials"
# 4. Edit your OAuth 2.0 Client ID or create a new one:
#    - Application type: "Web application"
#    - Name: "your-site - Production"
#    - Authorized JavaScript origins (replace with YOUR domain):
#      * https://www.your-domain.com
#      * https://your-domain.com
#    - Authorized redirect URIs (replace with YOUR domain):
#      * https://www.your-domain.com/api/auth/google/callback
#      * https://your-domain.com/api/auth/google/callback
#    - Click "Save"
# 5. Copy "Client ID" and "Client secret"
# 6. Fill in the values below
# 
# ⚠️ SECURITY NOTES:
# - Use DIFFERENT credentials than development
# - GOOGLE_CLIENT_SECRET is sensitive - never expose to client
# - NEXT_PUBLIC_* variables are exposed to browser (safe for Client ID)
# 
# ============================================================================

# Google OAuth Client ID (production)
# GitHub: ❌ DO NOT COMMIT | Vercel: ⚪ NOT SENSITIVE - Production/Preview
GOOGLE_CLIENT_ID=your-production-google-client-id

# Google OAuth Client Secret (production)
# GitHub: ❌ DO NOT COMMIT | Vercel: ✅ SENSITIVE - Production/Preview
GOOGLE_CLIENT_SECRET=your-production-google-client-secret

# Google OAuth Client ID (public - safe to expose)
# GitHub: ❌ DO NOT COMMIT | Vercel: ⚪ NOT SENSITIVE - Production/Preview
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-production-google-client-id

# Google OAuth Redirect URI (production)
# GitHub: ❌ DO NOT COMMIT | Vercel: ⚪ NOT SENSITIVE - Production/Preview
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=https://www.your-domain.com/api/auth/google/callback

# ============================================================================
# AUTHENTICATION & REGISTRATION (Required for enhanced registration)
# ============================================================================
# 
# Configuration for the enhanced authentication registration flow
# 
# ============================================================================

# API URL for registration endpoints
# GitHub: ❌ DO NOT COMMIT | Vercel: ⚪ NOT SENSITIVE - Production/Preview
# Session timeout in milliseconds (30 minutes = 1800000)
# GitHub: ❌ DO NOT COMMIT | Vercel: ⚪ NOT SENSITIVE - Production/Preview
SESSION_TIMEOUT=1800000

# Email verification token expiry in milliseconds (24 hours = 86400000)
# GitHub: ❌ DO NOT COMMIT | Vercel: ⚪ NOT SENSITIVE - Production/Preview
VERIFICATION_TOKEN_EXPIRY=86400000

# Cache configuration
# GitHub: ❌ DO NOT COMMIT | Vercel: ⚪ NOT SENSITIVE - Production/Preview
CACHE_ENABLED=true

# Cache TTL in seconds (1 hour)
# GitHub: ❌ DO NOT COMMIT | Vercel: ⚪ NOT SENSITIVE - Production/Preview
CACHE_TTL=3600

# Maximum cache memory
# GitHub: ❌ DO NOT COMMIT | Vercel: ⚪ NOT SENSITIVE - Production/Preview
CACHE_MAX_MEMORY=512mb

# Redis (optional). Vercel has no built-in Redis — use Upstash/Vercel KV and set REDIS_URL.
# Without REDIS_URL the app disables Redis cache automatically (see src/config/environment.ts).
# GitHub: ❌ DO NOT COMMIT | Vercel: ⚪ NOT SENSITIVE - Production/Preview
USE_REDIS=false
# REDIS_URL=redis://...  (only if you use Upstash or similar)

# ============================================================================
# SUPABASE (Required for database and auth)
# ============================================================================
# 
# How to set up for production:
# 
# Option 1: Use same project as development (not recommended)
# - Use the same credentials from .env.local
# 
# Option 2: Create separate production project (recommended)
# 1. Go to: https://supabase.com/
# 2. Create a new project:
#    - Name: "your-project"
#    - Database Password: (choose a STRONG password)
#    - Region: (choose closest to your users)
#    - Click "Create new project"
# 3. Wait for project to be ready
# 4. Go to "Settings" > "API"
# 5. Copy the credentials
# 6. Fill in the values below
# 
# ⚠️ SECURITY NOTES:
# - Use DIFFERENT project than development
# - SUPABASE_SERVICE_ROLE_KEY bypasses RLS - keep it secret!
# - Enable Row Level Security (RLS) on all tables
# - Set up proper database backups
# 
# ============================================================================

# Supabase Project URL (production)
# GitHub: ❌ DO NOT COMMIT | Vercel: ⚪ NOT SENSITIVE - Production/Preview
NEXT_PUBLIC_SUPABASE_URL=your-production-supabase-url

# Supabase Publishable Key (production)
# GitHub: ❌ DO NOT COMMIT | Vercel: ⚪ NOT SENSITIVE - Production/Preview
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-production-supabase-publishable-key

# Supabase Service Role Key (production - bypasses RLS)
# GitHub: ❌ DO NOT COMMIT | Vercel: ✅ SENSITIVE - Production/Preview
SUPABASE_SERVICE_ROLE_KEY=your-production-supabase-service-role-key

