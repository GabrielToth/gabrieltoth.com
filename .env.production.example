# Use a different key for production than development.
# 
# How to generate a secure encryption key:
# 
# 1. Use a cryptographically secure random string generator:
#    - Node.js: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#    - OpenSSL: openssl rand -hex 32
#    - Online: https://generate-secret.vercel.app/64
# 
# Note: Keep this secret! Never commit it to git or share it publicly.
# 
# ============================================================================

# Token Encryption Key (production)
# GitHub: ❌ DO NOT COMMIT | Vercel: ✅ SENSITIVE - Production/Preview
TOKEN_ENCRYPTION_KEY=your-production-64-character-hex-encryption-key

# ============================================================================
# SECURE PASSWORD STORAGE (Argon2id + Pepper + CAPTCHA)
# ============================================================================
# 
# Configuration for the secure password storage system
# Implements Argon2id (memory-hard) password hashing, pepper (server-side secret),
# and CAPTCHA protection against automated attacks
# 
# ============================================================================

# Argon2id Password Hashing Parameters (Tuned for Vercel Free Plan)
# 
# Memory Cost: 64 MB (reduced from standard 128-256 MB for 10-second timeout)
# Time Cost: 3 iterations (balance between security and performance)
# Parallelism: 2 threads (fits within Free Plan CPU allocation)
# 
# Expected hash generation time: 2-3 seconds per operation
# 
# When to increase (if moving to paid plan):
# - Memory: Increase to 128MB or more
# - Time: Increase iterations (max 10)
# - Parallelism: Increase threads (max 4)
# 
# CRITICAL: These values MUST be identical in both local Docker and production Vercel!
# Changing these requires rehashing all existing passwords.
# 
# GitHub: ❌ DO NOT COMMIT | Vercel: ⚪ NOT SENSITIVE - Production/Preview
ARGON2_MEMORY_COST=64

# GitHub: ❌ DO NOT COMMIT | Vercel: ⚪ NOT SENSITIVE - Production/Preview
ARGON2_TIME_COST=3

# GitHub: ❌ DO NOT COMMIT | Vercel: ⚪ NOT SENSITIVE - Production/Preview
ARGON2_PARALLELISM=2

# Pepper Secret (Server-side constant appended to passwords before hashing)
# 
# Purpose:
# - Adds security layer even if password hash database is compromised
# - Prevents offline password cracking without server access
# - Must be kept secret (never exposed, never in code)
# 
# Generation (choose one):
# - Node.js: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# - OpenSSL: openssl rand -hex 32
# - Online: https://generate-secret.vercel.app/64
# - Script: node scripts/generate-secrets.mjs
# 
# CRITICAL NOTES:
# - Must be at least 32 characters (64 hex chars)
# - Must be different from development pepper
# - Must be stored securely (Vercel Environment Variables only)
# - Changing pepper requires rehashing all passwords (don't do lightly)
# - Each environment (production, staging, local dev) should have unique pepper
# 
# How to set in Vercel:
# 1. Go to https://vercel.com/dashboard
# 2. Select your-domain.com project
# 3. Settings > Environment Variables
# 4. Add: Name=PEPPER_SECRET, Value=<your-generated-pepper>
# 5. Check "Sensitive" checkbox
# 6. Select Production and Preview
# 7. Save
# 
# GitHub: ❌ DO NOT COMMIT | Vercel: ✅ SENSITIVE - Production/Preview
PEPPER_SECRET=your-production-pepper-secret-64-hex-chars-minimum

# CAPTCHA Configuration (Bot Protection)
# 
# Provider options:
# - "cloudflare": Cloudflare Turnstile (RECOMMENDED - zero cost)
# - "google": Google reCAPTCHA v3 (alternative - free tier + paid)
# 
# Configuration for production (Cloudflare Turnstile):
# - CAPTCHA_PROVIDER=cloudflare
# - CAPTCHA_SECRET_KEY=<production secret from Cloudflare>
# - NEXT_PUBLIC_CAPTCHA_SITE_KEY=<production site key from Cloudflare>
# 
# How to set up Cloudflare Turnstile:
# 1. Go to: https://dash.cloudflare.com/?to=/:account/turnstile
# 2. Find your-domain.com domain challenge
# 3. Get Site Key (public) and Secret Key (sensitive)
# 4. In Vercel:
#    - CAPTCHA_PROVIDER = cloudflare (not sensitive)
#    - CAPTCHA_SECRET_KEY = <secret> (mark SENSITIVE)
#    - NEXT_PUBLIC_CAPTCHA_SITE_KEY = <site key> (not sensitive)
# 5. Select Production and Preview for each
# 6. Save
# 
# IMPORTANT:
# - CAPTCHA is required on registration AND login
# - Protects against brute force and account enumeration
# - Zero-cost with Cloudflare Turnstile recommended
# 
# GitHub: ❌ DO NOT COMMIT | Vercel: ⚪ NOT SENSITIVE - Production/Preview
CAPTCHA_PROVIDER=cloudflare

# GitHub: ❌ DO NOT COMMIT | Vercel: ✅ SENSITIVE - Production/Preview
CAPTCHA_SECRET_KEY=your-production-captcha-secret-key

# GitHub: ❌ DO NOT COMMIT | Vercel: ⚪ NOT SENSITIVE - Production/Preview
NEXT_PUBLIC_CAPTCHA_SITE_KEY=your-production-captcha-site-key

# Rate Limiting Configuration (Brute Force Protection)
# 
# Protects against:
# - Brute force password guessing (5 failures = 15-minute lockout)
# - Credential stuffing (tries of known password dumps)
# - Account enumeration (same error for all failures)
# 
# Configuration:
# - FAILURE_THRESHOLD: Number of failures before temporary lockout
# - WINDOW_MINUTES: Time window for counting failures
# - LOCKOUT_MINUTES: Duration of temporary account lockout
# - ESCALATION_THRESHOLD: Failures before CAPTCHA difficulty increases
# 
# Values configured for production (must match docker-compose.yml):
# - RATE_LIMIT_FAILURE_THRESHOLD=5
# - RATE_LIMIT_WINDOW_MINUTES=15
# - RATE_LIMIT_LOCKOUT_MINUTES=15
# - RATE_LIMIT_CAPTCHA_ESCALATION_THRESHOLD=3
# 
# How to set in Vercel:
# 1. Go to https://vercel.com/dashboard
# 2. Select your-domain.com project
# 3. Settings > Environment Variables
# 4. Add each variable (not marked as Sensitive):
#    - RATE_LIMIT_FAILURE_THRESHOLD = 5
#    - RATE_LIMIT_WINDOW_MINUTES = 15
#    - RATE_LIMIT_LOCKOUT_MINUTES = 15
#    - RATE_LIMIT_CAPTCHA_ESCALATION_THRESHOLD = 3
# 5. Select Production and Preview for each
# 6. DO NOT mark as Sensitive (these are not secrets)
# 7. Save
# 
# Typical values:
# - Strict (high security): 3 failures, 10 minute lockout
# - Standard (balanced): 5 failures, 15 minute lockout
# - Lenient (user-friendly): 10 failures, 30 minute lockout
# 
# GitHub: ❌ DO NOT COMMIT | Vercel: ⚪ NOT SENSITIVE - Production/Preview
RATE_LIMIT_FAILURE_THRESHOLD=5

# GitHub: ❌ DO NOT COMMIT | Vercel: ⚪ NOT SENSITIVE - Production/Preview
RATE_LIMIT_WINDOW_MINUTES=15

# GitHub: ❌ DO NOT COMMIT | Vercel: ⚪ NOT SENSITIVE - Production/Preview
RATE_LIMIT_LOCKOUT_MINUTES=15

# GitHub: ❌ DO NOT COMMIT | Vercel: ⚪ NOT SENSITIVE - Production/Preview
RATE_LIMIT_CAPTCHA_ESCALATION_THRESHOLD=3

