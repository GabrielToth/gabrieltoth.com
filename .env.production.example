# ============================================================================
# PRODUCTION ENVIRONMENT VARIABLES
# ============================================================================
# 
# ⚠️ IMPORTANT: DO NOT EDIT THIS FILE DIRECTLY!
# 
# 1. Copy this file to .env.production:
#    cp .env.production.example .env.production
# 
# 2. Fill in your actual PRODUCTION values in .env.production
# 
# 3. Never commit .env.production to git (it's in .gitignore)
# 
# 4. For Vercel deployment, set these in Project Settings > Environment Variables
# 
# ============================================================================
# 
# VERCEL DEPLOYMENT NOTES:
# 
# When deploying to Vercel, add these variables to Project Settings > Environment Variables:
# 
# SENSITIVE VARIABLES (Mark as "Sensitive" in Vercel):
# - GOOGLE_CLIENT_SECRET
# - SUPABASE_SERVICE_ROLE_KEY
# - STRIPE_SECRET_KEY
# - RESEND_API_KEY
# - YOUTUBE_CLIENT_SECRET
# - TOKEN_ENCRYPTION_KEY
# - JWT_SECRET
# - GEOIP_API_KEY
# - DISCORD_WEBHOOK_URL
# - SMTP_PASSWORD
# 
# PUBLIC VARIABLES (Do NOT mark as sensitive):
# - All NEXT_PUBLIC_* variables (these are exposed to browser by design)
# - DEPLOYMENT_TYPE
# - DEBUG
# - BCRYPT_COST_FACTOR
# - SESSION_TIMEOUT
# - VERIFICATION_TOKEN_EXPIRY
# - CACHE_ENABLED
# - CACHE_TTL
# - CACHE_MAX_MEMORY
# - USE_REDIS
# - SMTP_HOST
# - SMTP_PORT
# - SMTP_USER
# - SMTP_FROM_EMAIL
# - SMTP_FROM_NAME
# - GEOIP_SERVICE_URL
# - YOUTUBE_REDIRECT_URI
# 
# ============================================================================

# ============================================================================
# GENERAL SETTINGS
# ============================================================================

# Node environment (Vercel sets this automatically, but you can override)
# NODE_ENV=production

# Deployment type (local or cloud)
# Used by: src/config/environment.ts
# Vercel: ❌ PUBLIC | 🔴 Production, 🟡 Preview
DEPLOYMENT_TYPE=cloud

# Debug flags (should be FALSE in production for security and performance)
# Vercel: ❌ PUBLIC | 🔴 Production, 🟡 Preview
DEBUG=false
# Vercel: ❌ PUBLIC | 🔴 Production, 🟡 Preview
NEXT_PUBLIC_DEBUG=false

# Application URLs
# Used by: src/config/environment.ts
# Vercel: ❌ PUBLIC | 🔴 Production, 🟡 Preview
NEXT_PUBLIC_APP_URL=https://gabrieltoth.com
# Vercel: ❌ PUBLIC | 🔴 Production, 🟡 Preview
NEXT_PUBLIC_API_URL=https://gabrieltoth.com/api

# ============================================================================
# GOOGLE OAUTH (Required for Google Login)
# ============================================================================
# 
# How to set up for production:
# 
# 1. Go to: https://console.cloud.google.com/
# 2. Select your project
# 3. Go to "APIs & Services" > "Credentials"
# 4. Edit your OAuth 2.0 Client ID or create a new one:
#    - Application type: "Web application"
#    - Name: "gabrieltoth.com - Production"
#    - Authorized JavaScript origins:
#      * https://www.gabrieltoth.com
#      * https://gabrieltoth.com
#    - Authorized redirect URIs:
#      * https://www.gabrieltoth.com/api/auth/google/callback
#      * https://gabrieltoth.com/api/auth/google/callback
#    - Click "Save"
# 5. Copy "Client ID" and "Client secret"
# 6. Fill in the values below
# 
# ⚠️ SECURITY NOTES:
# - Use DIFFERENT credentials than development
# - GOOGLE_CLIENT_SECRET is sensitive - never expose to client
# - NEXT_PUBLIC_* variables are exposed to browser (safe for Client ID)
# 
# ============================================================================

# Vercel: ❌ PUBLIC | 🔴 Production, 🟡 Preview
GOOGLE_CLIENT_ID=your-production-google-client-id
# Vercel: ✅ SENSITIVE | 🔴 Production, 🟡 Preview
GOOGLE_CLIENT_SECRET=your-production-google-client-secret
# Vercel: ❌ PUBLIC | 🔴 Production, 🟡 Preview
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-production-google-client-id
# Vercel: ❌ PUBLIC | 🔴 Production, 🟡 Preview
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=https://www.gabrieltoth.com/api/auth/google/callback

# ============================================================================
# AUTHENTICATION & REGISTRATION (Required for enhanced registration)
# ============================================================================
# 
# Configuration for the enhanced authentication registration flow
# 
# ============================================================================

# API URL for registration endpoints
# Production: https://api.gabrieltoth.com or https://gabrieltoth.com/api
# Vercel: ❌ PUBLIC | 🔴 Production, 🟡 Preview
NEXT_PUBLIC_API_URL=https://gabrieltoth.com/api

# Bcrypt cost factor for password hashing (10-12 recommended)
# Higher = more secure but slower
# Vercel: ❌ PUBLIC | 🔴 Production, 🟡 Preview
BCRYPT_COST_FACTOR=12

# Session timeout in milliseconds (30 minutes = 1800000)
# Vercel: ❌ PUBLIC | 🔴 Production, 🟡 Preview
SESSION_TIMEOUT=1800000

# Email verification token expiry in milliseconds (24 hours = 86400000)
# Vercel: ❌ PUBLIC | 🔴 Production, 🟡 Preview
VERIFICATION_TOKEN_EXPIRY=86400000

# Cache configuration
# Used by: src/config/environment.ts
# Vercel: ❌ PUBLIC | 🔴 Production, 🟡 Preview
CACHE_ENABLED=true
# Vercel: ❌ PUBLIC | 🔴 Production, 🟡 Preview
CACHE_TTL=3600
# Vercel: ❌ PUBLIC | 🔴 Production, 🟡 Preview
CACHE_MAX_MEMORY=512mb
# Vercel: ❌ PUBLIC | 🔴 Production, 🟡 Preview
USE_REDIS=true

# ============================================================================
# SUPABASE (Required for database and auth)
# ============================================================================
# 
# How to set up for production:
# 
# Option 1: Use same project as development (not recommended)
# - Use the same credentials from .env.local
# 
# Option 2: Create separate production project (recommended)
# 1. Go to: https://supabase.com/
# 2. Create a new project:
#    - Name: "gabrieltoth-prod"
#    - Database Password: (choose a STRONG password)
#    - Region: (choose closest to your users)
#    - Click "Create new project"
# 3. Wait for project to be ready
# 4. Go to "Settings" > "API"
# 5. Copy the credentials
# 6. Fill in the values below
# 
# ⚠️ SECURITY NOTES:
# - Use DIFFERENT project than development
# - SUPABASE_SERVICE_ROLE_KEY bypasses RLS - keep it secret!
# - Enable Row Level Security (RLS) on all tables
# - Set up proper database backups
# 
# ============================================================================

# Vercel: ❌ PUBLIC | 🔴 Production, 🟡 Preview
NEXT_PUBLIC_SUPABASE_URL=your-production-supabase-url
# Vercel: ❌ PUBLIC | 🔴 Production, 🟡 Preview
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-production-supabase-publishable-key
# Vercel: ✅ SENSITIVE | 🔴 Production, 🟡 Preview
SUPABASE_SERVICE_ROLE_KEY=your-production-supabase-service-role-key

# ============================================================================
# STRIPE (Required for payments)
# ============================================================================
# 
# How to set up for production:
# 
# 1. Go to: https://dashboard.stripe.com/
# 2. Toggle "Test mode" OFF (top right)
# 3. Complete account activation if not done:
#    - Provide business details
#    - Verify identity
#    - Set up bank account for payouts
# 4. Go to "Developers" > "API keys"
# 5. Copy "Secret key" (starts with sk_live_)
# 6. Fill in the value below
# 
# ⚠️ SECURITY NOTES:
# - Use LIVE keys (sk_live_) for production
# - Never commit live keys to git
# - Rotate keys if compromised
# - Monitor Stripe dashboard for suspicious activity
# 
# ============================================================================

# Vercel: ✅ SENSITIVE | 🔴 Production, 🟡 Preview
STRIPE_SECRET_KEY=your-production-stripe-secret-key

# ============================================================================
# RESEND (Required for sending emails)
# ============================================================================
# 
# How to get Resend API key:
# 
# 1. Go to: https://resend.com/
# 2. Sign up or log in
# 3. Go to "API Keys"
# 4. Create a new API key
# 5. Copy the API key
# 6. Fill in the value below
# 
# Note: Resend is used for sending verification emails and password reset emails
# 
# ============================================================================

# Vercel: ✅ SENSITIVE | 🔴 Production, 🟡 Preview
RESEND_API_KEY=your-production-resend-api-key

# ============================================================================
# DISCORD WEBHOOK (Optional - for notifications)
# ============================================================================
# 
# How to set up for production:
# 
# Option 1: Use same webhook as development (not recommended)
# - Use the same URL from .env.local
# 
# Option 2: Create separate production webhook (recommended)
# 1. Create a separate Discord server or channel for production
# 2. Follow the same steps as development
# 3. Name webhook: "gabrieltoth.com Production"
# 4. Copy webhook URL
# 5. Fill in the value below
# 
# What it's used for:
# - User registration notifications
# - User login notifications
# - Error alerts (if configured)
# 
# ============================================================================

# Vercel: ✅ SENSITIVE | 🔴 Production, 🟡 Preview
DISCORD_WEBHOOK_URL=your-production-discord-webhook-url

# ============================================================================
# AMAZON ASSOCIATES (Optional - for affiliate links)
# ============================================================================
# 
# Same tag can be used for both development and production.
# Just copy from .env.local
# 
# ============================================================================

# Vercel: ❌ PUBLIC | 🔴 Production, 🟡 Preview
NEXT_PUBLIC_AMAZON_ASSOCIATES_TAG=your-amazon-tag

# ============================================================================
# MONERO (Optional - for cryptocurrency payments)
# ============================================================================
# 
# How to set up for production:
# 
# Option 1: Use same wallet as development (not recommended)
# - Use the same credentials from .env.local
# 
# Option 2: Create separate production wallet (recommended)
# 1. Create a new Monero wallet for production
# 2. Copy address and view key
# 3. Fill in the values below
# 
# ⚠️ SECURITY NOTES:
# - Use DIFFERENT wallet than development
# - Never share your spend key
# - Keep wallet backup in a safe place
# - Monitor transactions regularly
# 
# ============================================================================

# Vercel: ✅ SENSITIVE | 🔴 Production, 🟡 Preview
MONERO_ADDRESS=your-production-monero-address
# Vercel: ✅ SENSITIVE | 🔴 Production, 🟡 Preview
MONERO_VIEW_KEY=your-production-monero-view-key

# ============================================================================
# YOUTUBE OAUTH (Required for YouTube Channel Linking)
# ============================================================================
# 
# How to set up for production:
# 
# 1. Go to: https://console.cloud.google.com/
# 2. Select your project
# 3. Go to "APIs & Services" > "Credentials"
# 4. Edit your OAuth 2.0 Client ID or create a new one:
#    - Application type: "Web application"
#    - Name: "gabrieltoth.com - YouTube Linking Production"
#    - Authorized JavaScript origins:
#      * https://www.gabrieltoth.com
#      * https://gabrieltoth.com
#    - Authorized redirect URIs:
#      * https://www.gabrieltoth.com/api/youtube/link/callback
#      * https://gabrieltoth.com/api/youtube/link/callback
#    - Click "Save"
# 5. Copy "Client ID" and "Client secret"
# 6. Fill in the values below
# 
# ⚠️ SECURITY NOTES:
# - Use DIFFERENT credentials than development
# - YOUTUBE_CLIENT_SECRET is sensitive - never expose to client
# - Mark as sensitive in Vercel environment variables
# 
# ============================================================================

# Vercel: ❌ PUBLIC | 🔴 Production, 🟡 Preview
YOUTUBE_CLIENT_ID=your-production-youtube-client-id
# Vercel: ✅ SENSITIVE | 🔴 Production, 🟡 Preview
YOUTUBE_CLIENT_SECRET=your-production-youtube-client-secret
# Vercel: ❌ PUBLIC | 🔴 Production, 🟡 Preview
YOUTUBE_REDIRECT_URI=https://gabrieltoth.com/api/youtube/link/callback

# ============================================================================
# JWT SECRET (Required for OAuth Registration)
# ============================================================================
# 
# Secret key for signing temporary JWT tokens during OAuth registration.
# Use a different secret for production than development.
# 
# How to generate a secure JWT secret:
# 
# 1. Use a cryptographically secure random string generator:
#    - Node.js: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#    - OpenSSL: openssl rand -hex 64
#    - Online: https://generate-secret.vercel.app/64
# 
# Note: Keep this secret secure! Never commit it to git or share it publicly.
# 
# ============================================================================

# Vercel: ✅ SENSITIVE | 🔴 Production, 🟡 Preview
JWT_SECRET=your-production-jwt-secret-key

# ============================================================================
# SMTP CONFIGURATION (Required for sending emails)
# ============================================================================
# 
# Configuration for sending verification emails and password reset emails
# 
# How to set up Gmail SMTP:
# 
# 1. Enable 2-Factor Authentication on your Google account:
#    - Go to: https://myaccount.google.com/security
#    - Enable "2-Step Verification"
# 
# 2. Generate an App Password:
#    - Go to: https://myaccount.google.com/apppasswords
#    - Select "Mail" and "Windows Computer" (or your device)
#    - Google will generate a 16-character password
#    - Copy this password to SMTP_PASSWORD below
# 
# 3. Fill in the values:
#    - SMTP_HOST: smtp.gmail.com (for Gmail)
#    - SMTP_PORT: 587 (TLS) or 465 (SSL)
#    - SMTP_USER: your-email@gmail.com
#    - SMTP_PASSWORD: your-16-character-app-password
#    - SMTP_FROM_EMAIL: noreply@gabrieltoth.com (or your domain)
#    - SMTP_FROM_NAME: Gabriel Toth (or your name)
# 
# For other email providers:
# - SendGrid: smtp.sendgrid.net:587, user: apikey, password: SG.xxxxx
# - Mailgun: smtp.mailgun.org:587, user: postmaster@xxx, password: xxxxx
# - AWS SES: email-smtp.region.amazonaws.com:587, user: AKIA..., password: xxxxx
# 
# ============================================================================

# Vercel: ❌ PUBLIC | 🔴 Production, 🟡 Preview
SMTP_HOST=smtp.gmail.com
# Vercel: ❌ PUBLIC | 🔴 Production, 🟡 Preview
SMTP_PORT=587
# Vercel: ❌ PUBLIC | 🔴 Production, 🟡 Preview
SMTP_USER=your-production-email@gmail.com
# Vercel: ✅ SENSITIVE | 🔴 Production, 🟡 Preview
SMTP_PASSWORD=your-production-app-password
# Vercel: ❌ PUBLIC | 🔴 Production, 🟡 Preview
SMTP_FROM_EMAIL=noreply@gabrieltoth.com
# Vercel: ❌ PUBLIC | 🔴 Production, 🟡 Preview
SMTP_FROM_NAME=Gabriel Toth

# ============================================================================
# TOKEN ENCRYPTION (Required for YouTube OAuth Token Storage)
# ============================================================================
# 
# Encryption key for storing OAuth tokens securely
# Use a different key for production than development.
# 
# How to generate a secure encryption key:
# 
# 1. Use a cryptographically secure random string generator:
#    - Node.js: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#    - OpenSSL: openssl rand -hex 32
#    - Online: https://generate-secret.vercel.app/64
# 
# Note: Keep this secret! Never commit it to git or share it publicly.
# 
# ============================================================================

# Vercel: ✅ SENSITIVE | 🔴 Production, 🟡 Preview
TOKEN_ENCRYPTION_KEY=your-production-64-character-hex-encryption-key

# ============================================================================
# GEOLOCATION SERVICE (Optional - for Suspicious Activity Detection)
# ============================================================================
# 
# Configuration for IP geolocation and device tracking
# 
# How to get MaxMind GeoIP2 credentials:
# 
# 1. Go to: https://www.maxmind.com/en/geoip2-services
# 2. Sign up for a free account
# 3. Go to "Account" > "My License Key"
# 4. Generate a new license key
# 5. Copy the Account ID and License Key
# 6. Fill in the values below
# 
# Alternative services:
# - IP2Location: https://www.ip2location.com/
# - GeoIP2: https://www.maxmind.com/
# - ipstack: https://ipstack.com/
# 
# ============================================================================

# Vercel: ❌ PUBLIC | 🔴 Production, 🟡 Preview
GEOIP_SERVICE_URL=https://geoip.maxmind.com/geoip/v2.1/city
# Vercel: ✅ SENSITIVE | 🔴 Production, 🟡 Preview
GEOIP_API_KEY=your-production-maxmind-license-key

