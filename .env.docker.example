# ============================================================================
# DOCKER ENVIRONMENT VARIABLES
# ============================================================================
# 
# ⚠️ IMPORTANT: DO NOT EDIT THIS FILE DIRECTLY!
# 
# 1. Copy this file to .env.docker:
#    cp .env.docker.example .env.docker
# 
# 2. Fill in your actual values in .env.docker
# 
# 3. Never commit .env.docker to git (it's in .gitignore)
# 
# 4. These variables are used by docker-compose.yml
# 
# ============================================================================

# ============================================================================
# POSTGRESQL (Required for Docker)
# ============================================================================
# 
# These values are used by the postgres service in docker-compose.yml
# 
# Default values are fine for local development.
# Change them if you want different credentials.
# 
# ============================================================================

POSTGRES_USER=platform
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=platform

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Debug mode (true = verbose logging)
DEBUG=true

# Base URL for the application
# Use http://localhost:3000 for local development
BASE_URL=http://localhost:3000

# ============================================================================
# DISCORD WEBHOOK (Optional)
# ============================================================================
# 
# If you want Docker containers to send notifications to Discord:
# 1. Follow the instructions in .env.local.example to get webhook URL
# 2. Fill in the value below
# 
# If you don't need notifications, leave it empty or remove this line.
# 
# ============================================================================

DISCORD_WEBHOOK_URL=

# ============================================================================
# STRIPE (Optional)
# ============================================================================
# 
# If you want to test Stripe payments in Docker:
# 1. Follow the instructions in .env.local.example to get Stripe keys
# 2. Fill in the values below
# 
# If you don't need payments, leave them empty or remove these lines.
# 
# ============================================================================

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================================================
# DOCKER USAGE
# ============================================================================
# 
# After setting up this file:
# 
# 1. Navigate to docker directory:
#    cd docker
# 
# 2. Start all services:
#    docker compose up -d
# 
# 3. Check status:
#    docker compose ps
# 
# 4. View logs:
#    docker compose logs -f
# 
# 5. Stop services:
#    docker compose down
# 
# 6. Stop and remove volumes (⚠️ deletes data):
#    docker compose down -v
# 
# ============================================================================

# ============================================================================
# SERVICES
# ============================================================================
# 
# Docker Compose will start these services:
# 
# - postgres:5432   - PostgreSQL database
# - redis:6379      - Redis cache (optional, not implemented yet)
# - app:3000        - Next.js application
# - backend:4000    - Backend API (if configured)
# 
# Access URLs:
# - Frontend: http://localhost:3000
# - Backend: http://localhost:4000
# - Postgres: localhost:5432
# - Redis: localhost:6379
# 
# ============================================================================

# ============================================================================
# TROUBLESHOOTING
# ============================================================================
# 
# If services don't start:
# 
# 1. Check if ports are already in use:
#    netstat -an | findstr "3000 4000 5432 6379"
# 
# 2. View service logs:
#    docker compose logs postgres
#    docker compose logs redis
#    docker compose logs app
# 
# 3. Rebuild containers:
#    docker compose build --no-cache
#    docker compose up -d
# 
# 4. Remove all volumes and start fresh:
#    docker compose down -v
#    docker compose up -d
# 
# ============================================================================
