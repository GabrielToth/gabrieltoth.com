{
    "name": "gabrieltoth.com",
    "version": "1.23.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "docs:schema": "node scripts/generate-schema-docs.js",
        "lint": "eslint \"src/**/*.{ts,tsx}\"",
        "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "type-check": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
        "spell-check": "cspell \"src/**/*.{ts,tsx,js,jsx,md,json}\"",
        "spell-check:fix": "cspell \"src/**/*.{ts,tsx,js,jsx,md,json}\" --fix",
        "test": "vitest --run --passWithNoTests",
        "test:unit": "vitest --run --passWithNoTests",
        "test:watch": "vitest --watch",
        "test:coverage": "vitest --run --coverage",
        "test:all": "npm run type-check && npm run lint && npm run markdownlint && npm run format:check && npm run spell-check && npm test",
        "markdownlint": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#.next\" \"#coverage\" \"#dist\" \"#out\" \"#build\" \"#.git\" \"#playwright-report\" \"#storybook-static\" \"#.venv\" \"#.kiro\" \"#.agents\" \"#.gemini\" \"#.opencode\"",
        "clean": "Remove-Item -Recurse -Force .next, dist, out -ErrorAction SilentlyContinue",
        "prepare": "husky",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:report": "playwright show-report",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "analyze": "ANALYZE=true npm run build",
        "analyze:open": "ANALYZE=true npm run build && open .next/analyze",
        "lighthouse": "lhci autorun",
        "lighthouse:ci": "lhci collect && lhci assert",
        "perf": "npm run build && npm run analyze",
        "perf:full": "npm run build && npm run analyze && npm run lighthouse",
        "bundle:size": "npm run build && node -e \"const fs=require('fs'); const path=require('path'); const getBundleSize=dir=>{let size=0; fs.readdirSync(dir).forEach(file=>{const filePath=path.join(dir,file); const stat=fs.statSync(filePath); if(stat.isDirectory()){size+=getBundleSize(filePath);}else{size+=stat.size;}}); return size;}; console.log('Bundle size:', (getBundleSize('.next')/1024/1024).toFixed(2) + 'MB');\"",
        "metrics:gsc": "node scripts/gsc-api-extract.js",
        "metrics:psi": "node scripts/psi-extract.js",
        "supabase": "supabase",
        "db:push": "supabase db push",
        "db:types": "supabase gen types typescript --linked > src/types/supabase.ts",
        "db:types:local": "supabase gen types typescript --local > src/types/supabase.ts",
        "db:migrate": "powershell -File scripts/apply-migration.ps1 local",
        "db:migrate:remote": "powershell -File scripts/apply-migration.ps1 remote"
    },
    "devDependencies": {
        "@chromatic-com/storybook": "^5.1.2",
        "@cspell/dict-de-de": "^4.1.2",
        "@cspell/dict-es-es": "^3.0.8",
        "@cspell/dict-pt-br": "^2.4.2",
        "@eslint/eslintrc": "^3.3.5",
        "@fast-check/vitest": "^0.4.0",
        "@lhci/cli": "^0.15.1",
        "@next/bundle-analyzer": "^16.2.4",
        "@playwright/test": "^1.59.1",
        "@storybook/addon-a11y": "^10.3.5",
        "@storybook/addon-docs": "^10.3.5",
        "@storybook/addon-onboarding": "^10.3.5",
        "@storybook/nextjs": "^10.4.0",
        "@storybook/react": "^10.4.0",
        "@tailwindcss/aspect-ratio": "^0.4.2",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/postcss": "^4.2.2",
        "@tailwindcss/typography": "^0.5.19",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^26.0.0",
        "@types/node-cron": "^3.0.11",
        "@types/pg": "^8.20.0",
        "@types/qrcode": "^1.5.6",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/uuid": "^10.0.0",
        "@typescript-eslint/eslint-plugin": "^8.58.2",
        "@typescript-eslint/parser": "^8.58.2",
        "@vitest/coverage-v8": "^4.1.4",
        "cspell": "^10.0.0",
        "cspell-dict-pt-br": "^1.1.1",
        "eslint": "^10.7.0",
        "eslint-config-next": "^16.2.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-storybook": "^10.3.5",
        "fast-check": "^4.6.0",
        "husky": "^9.1.7",
        "jsdom": "^29.0.2",
        "lint-staged": "^17.0.7",
        "markdownlint-cli2": "^0.23.0",
        "node-fetch": "^3.3.2",
        "prettier": "^3.8.3",
        "storybook": "^10.3.5",
        "supabase": "^2.105.0",
        "tailwindcss": "^4.2.2",
        "tw-animate-css": "^1.4.0",
        "typescript": "^7.0.2",
        "vitest": "^4.1.4",
        "webpack-bundle-analyzer": "^5.3.0"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx}": [
            "prettier --write",
            "eslint --fix"
        ],
        "*.{json,css,md}": [
            "prettier --write"
        ],
        "*.md": [
            "markdownlint-cli2 --fix"
        ]
    },
    "engines": {
        "node": "24.x",
        "npm": ">=10.0.0"
    },
    "dependencies": {
        "@icons-pack/react-simple-icons": "^13.13.0",
        "@radix-ui/react-checkbox": "^1.3.3",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-tabs": "^1.1.13",
        "@radix-ui/react-toggle": "^1.1.10",
        "@supabase/ssr": "^0.12.0",
        "@supabase/supabase-js": "^2.108.2",
        "@swc/helpers": "^0.5.23",
        "@upstash/ratelimit": "^2.0.8",
        "@upstash/redis": "^1.37.0",
        "@vercel/analytics": "^2.0.1",
        "@vercel/speed-insights": "^2.0.0",
        "argon2": "^0.44.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "date-fns-tz": "^3.2.0",
        "googleapis": "^173.0.0",
        "jsonwebtoken": "^9.0.3",
        "libphonenumber-js": "^1.12.41",
        "lucide-react": "^1.8.0",
        "next": "^16.2.7",
        "next-intl": "^4.9.1",
        "node-cron": "^4.2.1",
        "node-domexception": "^2.0.2",
        "pg": "^8.20.0",
        "qrcode": "^1.5.4",
        "qrcode.react": "^4.2.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-icons": "^5.6.0",
        "react-international-phone": "^4.8.0",
        "resend": "^6.16.0",
        "tailwind-merge": "^3.5.0",
        "web-vitals": "^5.2.0"
    },
    "overrides": {
        "tmp": "^0.2.4",
        "undici": ">=7.28.0 <8.0.0",
        "form-data": ">=4.0.6",
        "protobufjs": ">=7.6.3",
        "esbuild": ">=0.28.1",
        "elliptic": ">=6.6.1",
        "postcss": ">=8.5.10",
        "markdown-it": ">=14.2.0",
        "uuid": ">=11.1.1",
        "js-yaml": ">=4.2.0 <5.0.0",
        "rimraf": ">=5.0.0",
        "glob": ">=10.0.0"
    }
}
