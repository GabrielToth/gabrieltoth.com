                            "eslint-config-prettier":  "^10.1.8",
                            "eslint-plugin-jsx-a11y":  "^6.10.2",
                            "eslint-plugin-react":  "^7.37.5",
                            "eslint-plugin-react-hooks":  "^7.1.1",
                            "eslint-plugin-storybook":  "^10.5.0",
                            "fast-check":  "^4.9.0",
                            "husky":  "^9.1.7",
                            "jsdom":  "^29.1.1",
                            "lint-staged":  "^17.0.8",
                            "markdownlint-cli2":  "^0.23.0",
                            "node-fetch":  "^3.3.2",
                            "prettier":  "^3.9.5",
                            "storybook":  "^10.5.0",
