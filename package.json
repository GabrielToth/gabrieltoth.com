{
    "name":  "gabrieltoth.com",
    "version":  "1.24.0",
    "private":  true,
    "scripts":  {
                    "dev":  "next dev",
                    "start":  "next start",
                    "docs:schema":  "node scripts/generate-schema-docs.js",
                    "lint":  "eslint \"src/**/*.{ts,tsx}\"",
                    "lint:fix":  "eslint \"src/**/*.{ts,tsx}\" --fix",
                    "format":  "prettier --write .",
                    "format:check":  "prettier --check .",
                    "type-check":  "tsc --noEmit \u0026\u0026 tsc --noEmit -p tsconfig.test.json",
                    "spell-check":  "cspell \"src/**/*.{ts,tsx,js,jsx,md,json}\"",
                    "spell-check:fix":  "cspell \"src/**/*.{ts,tsx,js,jsx,md,json}\" --fix",
                    "test":  "vitest --run --passWithNoTests",
                    "test:unit":  "vitest --run --passWithNoTests",
                    "test:watch":  "vitest --watch",
                    "test:coverage":  "vitest --run --coverage",
                    "test:all":  "npm run type-check \u0026\u0026 npm run lint \u0026\u0026 npm run markdownlint \u0026\u0026 npm run format:check \u0026\u0026 npm run spell-check \u0026\u0026 npm test",
                    "markdownlint":  "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#.next\" \"#coverage\" \"#dist\" \"#out\" \"#build\" \"#.git\" \"#playwright-report\" \"#storybook-static\" \"#.venv\" \"#.kiro\" \"#.agents\" \"#.gemini\" \"#.opencode\"",
                    "clean":  "Remove-Item -Recurse -Force .next, dist, out -ErrorAction SilentlyContinue",
                    "prepare":  "husky",
                    "test:e2e":  "playwright test",
                    "test:e2e:ui":  "playwright test --ui",
                    "test:e2e:headed":  "playwright test --headed",
                    "test:e2e:report":  "playwright show-report",
                    "storybook":  "storybook dev -p 6006",
                    "build-storybook":  "storybook build",
                    "analyze":  "ANALYZE=true npm run build",
                    "analyze:open":  "ANALYZE=true npm run build \u0026\u0026 open .next/analyze",
                    "lighthouse":  "lhci autorun",
                    "lighthouse:ci":  "lhci collect \u0026\u0026 lhci assert",
                    "perf":  "npm run build \u0026\u0026 npm run analyze",
                    "perf:full":  "npm run build \u0026\u0026 npm run analyze \u0026\u0026 npm run lighthouse",
                    "bundle:size":  "npm run build \u0026\u0026 node -e \"const fs=require(\u0027fs\u0027); const path=require(\u0027path\u0027); const getBundleSize=dir=\u003e{let size=0; fs.readdirSync(dir).forEach(file=\u003e{const filePath=path.join(dir,file); const stat=fs.statSync(filePath); if(stat.isDirectory()){size+=getBundleSize(filePath);}else{size+=stat.size;}}); return size;}; console.log(\u0027Bundle size:\u0027, (getBundleSize(\u0027.next\u0027)/1024/1024).toFixed(2) + \u0027MB\u0027);\"",
                    "metrics:gsc":  "node scripts/gsc-api-extract.js",
                    "metrics:psi":  "node scripts/psi-extract.js",
                    "supabase":  "supabase",
                    "db:push":  "supabase db push",
                    "db:types":  "supabase gen types typescript --linked \u003e src/types/supabase.ts",
                    "db:types:local":  "supabase gen types typescript --local \u003e src/types/supabase.ts",
                    "db:migrate":  "powershell -File scripts/apply-migration.ps1 local",
                    "db:migrate:remote":  "powershell -File scripts/apply-migration.ps1 remote",
                    "build":  "next build"
                },
    "devDependencies":  {
